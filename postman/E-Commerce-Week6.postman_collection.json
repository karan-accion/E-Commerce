            },
            "url": {
              "raw": "http://localhost:8080/users",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "users"
              ]
            },
            "description": "Create a new user in the MySQL database"
